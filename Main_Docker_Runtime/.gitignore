# ==============================================================================
# DB 런타임 데이터 (컨테이너가 생성하는 데이터 — 내용물 제외, 폴더 존재만 추적)
# ==============================================================================
# PostgreSQL 데이터
db/data/**
!db/data/.gitkeep

# Redis 데이터
db/redis_data/**
!db/redis_data/.gitkeep

# ==============================================================================
# SSL 인증서 (절대 커밋 금지 — 개인키 포함)
# ==============================================================================
certbot/conf/**
!certbot/conf/.gitkeep
certbot/www/**
!certbot/www/.gitkeep

# ==============================================================================
# 사용자 업로드 파일
# ==============================================================================
uploads/**
!uploads/.gitkeep

# ==============================================================================
# 환경 변수 (절대 커밋 금지)
# ==============================================================================
setting/.env
.env

# ==============================================================================
# Python 빌드 산출물
# ==============================================================================
__pycache__/
*.pyc
*.pyo
.pytest_cache/
